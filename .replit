modules = ["nodejs-20"]
[nix]
channel = "stable-25_05"
packages = ["unzip"]

[agent]
expertMode = true

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Betrayal Game"

[[workflows.workflow]]
name = "Betrayal Game"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd \"Betrayal Game\" && npm run dev"

[workflows.workflow.metadata]
outputType = "console"

[[ports]]
localPort = 3000
externalPort = 80
